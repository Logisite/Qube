export function useCardAnimation(
  progress: MotionValue<number>,
  index: number,
  totalCards: number,
): CardAnimation {
  const segmentSize = 1 / totalCards
  const start = index * segmentSize
  const end = start + segmentSize
  const isHero = index === 0
  const isLast = index === totalCards - 1

  const enterEnd = start + segmentSize * 0.20
  const activeEnd = start + segmentSize * 0.70
  const exitEnd = end

  const y = isHero
    ? useTransform(progress, [start, activeEnd, exitEnd], ["0vh", "0vh", "-8vh"], { clamp: true })
    : useTransform(progress, [start, enterEnd, activeEnd, exitEnd], ["100vh", "0vh", "0vh", "-8vh"], { clamp: true })

  const scale = isHero
    ? useTransform(progress, [start, activeEnd, exitEnd], [1, 1, 0.9], { clamp: true })
    : isLast
      ? useTransform(progress, [start, enterEnd, exitEnd], [0.96, 1, 1], { clamp: true })
      : useTransform(progress, [start, enterEnd, activeEnd, exitEnd], [0.96, 1, 1, 0.9], { clamp: true })

  const opacity = isHero
    ? useTransform(progress, [start, activeEnd, exitEnd], [1, 1, 0], { clamp: true })
    : isLast
      ? useTransform(progress, [start, enterEnd], [0, 1], { clamp: true })
      : useTransform(progress, [start, start + segmentSize * 0.15, activeEnd, exitEnd], [0, 1, 1, 0], { clamp: true })

  const blur = isLast
    ? useTransform(() => 0)
    : useTransform(progress, [activeEnd, exitEnd], [0, 8], { clamp: true })

  const borderRadius = useTransform(() => "32px")

  return {
    y,
    scale,
    opacity,
    blur,
    borderRadius,
    segmentStart: start,
    segmentEnd: end,
  }
} 

